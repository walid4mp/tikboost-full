# ===== Server =====
NODE_ENV=production
PORT=4000
APP_NAME=TikBoost
APP_URL=https://your-render-service.onrender.com

# ===== Database =====
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tikboost

# ===== Auth =====
JWT_ACCESS_SECRET=replace_me_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_me_with_a_long_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
BCRYPT_ROUNDS=10

# ===== Admin =====
SEED_ADMIN_EMAIL=admin@tikboost.app
SEED_ADMIN_PASSWORD=ChangeMeBeforeProduction_2026!
SEED_ADMIN_NAME=Super Admin

# ===== Anti-abuse =====
TASK_COOLDOWN_SECONDS=8
MAX_CAMPAIGNS_PER_USER=20
FREEZE_DURATION_MIN=60

# ===== Socket.io / CORS =====
SOCKET_CORS_ORIGIN=*

# ===== Features =====
ENABLE_GOOGLE_LOGIN=true
